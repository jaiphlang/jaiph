#!/usr/bin/env jaiph

import "./ensure_ci_passes.jh" as ci
import "./git.jh" as git

config {
  agent.backend = "claude"
  agent.claude_flags = "--permission-mode bypassPermissions"
}

script read_contributing_docs {
  test -f docs/contributing.md || {
    echo "docs/contributing.md not found (run from repo root)" >&2
    return 1
  }
  awk '
/^---$/ {
  if (sec == 0) { sec = 1; next }
  if (sec == 1) { sec = 2; next }
}
sec == 1 { next }
sec == 2 { print }
' docs/contributing.md
}

script new_qa_gap_report_path {
  echo ".jaiph/tmp/qa_gap_report_$(date +%Y-%m-%d_%H-%M-%S).md"
}

script write_gap_report_pointer {
  printf '%s\n' "$1" > .jaiph/tmp/qa_gap_report_active.txt
}

script gap_report_nonempty {
  p="$(cat .jaiph/tmp/qa_gap_report_active.txt 2>/dev/null)" || return 1
  [ -z "$p" ] && return 1
  test -s "$p"
}

script read_gap_report {
  p="$(cat .jaiph/tmp/qa_gap_report_active.txt)"
  cat "$p"
}

script save_gap_report_file {
  printf '%s\n' "$1" > "$2"
}

workflow analyze_gaps {
  const report_path = run new_qa_gap_report_path()
  const contributing_docs = run read_contributing_docs()
  const gap_report = prompt "
    <role>
    You are a QA engineer analyzing the Jaiph codebase for test coverage gaps.

    <contributing_docs>
    ${contributing_docs}
    </contributing_docs>

    Use the testing philosophy and layer locations from contributing_docs above
    (module tests colocated under src/, compiler golden/acceptance under
    src/transpile/, cross-cutting tests and shared fixtures under test/, e2e under
    e2e/tests/). Do not invent old layouts (e.g. a root test/acceptance/ tree for the
    compiler); follow the tables in contributing_docs.

    <task>
    Your task:
    1. Read every source file in src/parse/*.ts and list each parser branch
       (rule, workflow, script, env, import, config, test blocks, conditionals,
       recover, prompt, send, routes). For each branch, check coverage per
       contributing_docs (colocated parse tests, transpile acceptance/golden, etc.).
       List branches with no test.

    2. Read src/transpile/emit-workflow.ts and src/transpile/emit-test.ts.
       For each emission branch (ensure, run, prompt, shell, if-variants, send,
       log, logerr, recover loops, metadata scope), check compiler golden and
       acceptance coverage as described in contributing_docs. List gaps.

    3. Read e2e/tests/*.sh file names and compare against the feature list in
       docs/grammar.md and docs/cli.md. List features with no e2e test.

    4. Read src/cli/commands/*.ts and src/cli/run/*.ts. List error paths,
       edge cases, and config-resolution branches that have no test coverage.

    5. Scan src/ for pure helpers or modules without colocated *.test.ts or
       *.acceptance.test.ts and not covered by cross-cutting tests in test/.
       List gaps.

    Output a structured gap report in this format, one entry per gap:

    ## Gap: [short description]
    - File: [source file with untested code path]
    - Code path: [specific branch/function/line range]
    - Why it matters: [what bug this could hide]
    - Test type: [unit | acceptance | golden | e2e] (per contributing_docs)
    - Priority: [high | medium | low]

    Sort by priority descending. Be thorough but skip trivial paths (like
    simple re-exports or type definitions).
    </task>
    </role>
  "

  run save_gap_report_file("${gap_report}", "${report_path}")
  run write_gap_report_pointer("${report_path}")
  log "Gap report saved to ${report_path}"
}

workflow write_tests {
  if not run gap_report_nonempty() {
    fail "No gap report found (see .jaiph/tmp/qa_gap_report_active.txt). Run analyze_gaps first."
  }
  const gap_report = run read_gap_report()
  const contributing_docs = run read_contributing_docs()

  prompt "
    <role>
    You are a test engineer for the Jaiph codebase.

    <contributing_docs>
    ${contributing_docs}
    </contributing_docs>

    Follow contributing_docs for test layer choice, file locations, npm commands,
    and E2E helpers (e2e/lib/common.sh). CI expectations are summarized there
    (.github/workflows/ci.yml is the machine-readable source).

    <task>
    Below is a gap report listing untested code paths, sorted by priority.
    Your task: write the missing tests, starting with high-priority gaps.

    Rules:
    - Place tests where contributing_docs says (colocated under src/, golden/
      acceptance under src/transpile/, cross-cutting under test/, e2e under
      e2e/tests/).
    - Do NOT modify existing tests.
    - Do NOT modify production code.
    - After writing tests, run: npm run build && npm test && npm run test:e2e
    - Fix any test failures that come from your new tests (wrong expectations,
      typos, etc). If a new test exposes a production bug, do NOT leave an
      intentionally failing test in the suite; instead document the bug in
      .jaiph/tmp/qa_bug_report.md with repro steps and mark the test as TODO
      or skip with a clear comment.

    Gap report:
    ${gap_report}
    </task>
    </role>
  "
}

script mkdir_tmp_jaiph_qa {
  mkdir -p .jaiph/tmp
}

workflow default {
  # ensure git.is_clean()
  run mkdir_tmp_jaiph_qa()
  run analyze_gaps()
  run write_tests()
  run ci.ensure_ci_passes()
}
