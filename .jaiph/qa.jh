#!/usr/bin/env jaiph

import "./ensure_ci_passes.jh" as ci
import "./git.jh" as git

config {
  agent.backend = "claude"
  agent.claude_flags = "--permission-mode bypassPermissions"
}

const testing_philosophy = "
  Jaiph has four test layers. Use the narrowest layer that covers the behavior.

  1. Unit tests (test/*.test.ts) — pure functions: event parsing, param
     formatting, path resolution, config merging. Input in, output out, no I/O.
  2. Compiler acceptance tests (test/acceptance/*.test.ts) — parser/transpiler
     edge cases: malformed input, error messages, boundary conditions.
  3. Golden output tests (test/fixtures/ + test/expected/) — compiler
     regressions: verifies .jh input produces exact .sh output. Update
     test/expected/ when a change is intentional.
  4. E2E tests (e2e/tests/*.sh) — runtime behavior: does the built workflow
     actually execute correctly? Uses helpers from e2e/lib/common.sh with
     Given/When/Then structure.

  Key rules:
  - Tests are behavior contracts. Change production code to satisfy tests,
    not vice versa.
  - E2E tests assert two things independently: CLI tree output and runtime
    artifacts. Default contract is full equality: use e2e::expect_stdout
    (heredoc), e2e::expect_out, e2e::expect_rule_out, e2e::expect_file,
    e2e::expect_run_file, or e2e::assert_equals / e2e::assert_output_equals
    on captured stdout/stderr and file contents. e2e::assert_contains
    (substring check) is the exception, not the default — every use must
    have an inline comment explaining why full equality is not feasible.
    Allowed reasons: nondeterministic output (real agent backends, timestamps
    not covered by <time> normalization), unbounded or variable-length logs
    (run_summary.jsonl with platform-dependent event counts), or
    platform-dependent text (OS-specific error messages, differing paths).
    See ARCHITECTURE.md — E2E test philosophy for the full policy.
  - Prefer the narrowest test layer. A pure function bug = unit test.
    A runtime integration bug = e2e test.
  - Modify existing tests only for intentional behavior changes, incorrect
    expectations, or obsolete feature removal. Keep changes minimal.
"

script gap_report_nonempty() {
  test -s ".jaiph/tmp/qa_gap_report.md"
}

script read_gap_report() {
  cat .jaiph/tmp/qa_gap_report.md
}

script save_gap_report() {
  printf '%s\n' "$1" > .jaiph/tmp/qa_gap_report.md
}

workflow analyze_gaps() {
  const gap_report = prompt "
    <role>
    You are a QA engineer analyzing the Jaiph codebase for test coverage gaps.

    <testing_philosophy>
    ${testing_philosophy}

    <task>
    Your task:
    1. Read every source file in src/parse/*.ts and list each parser branch
       (rule, workflow, script, env, import, config, test blocks, conditionals,
       recover, prompt, send, routes). For each branch, check if test/acceptance/
       or test/fixtures/ has a corresponding test case. List branches with no test.

    2. Read src/transpile/emit-workflow.ts and src/transpile/emit-test.ts.
       For each emission branch (ensure, run, prompt, shell, if-variants, send,
       log, logerr, recover loops, metadata scope), check if test/expected/
       has a golden fixture covering it. List branches with no golden coverage.

    3. Read e2e/tests/*.sh file names and compare against the feature list in
       docs/grammar.md and docs/cli.md. List features with no e2e test.

    4. Read src/cli/commands/*.ts and src/cli/run/*.ts. List error paths,
       edge cases, and config-resolution branches that have no test coverage.

    5. Read test/*.test.ts. List pure utility functions in src/ that have no
       unit test.

    Output a structured gap report in this format, one entry per gap:

    ## Gap: [short description]
    - File: [source file with untested code path]
    - Code path: [specific branch/function/line range]
    - Why it matters: [what bug this could hide]
    - Test type: [unit | acceptance | golden | e2e]
    - Priority: [high | medium | low]

    Sort by priority descending. Be thorough but skip trivial paths (like
    simple re-exports or type definitions).
    </task>
    </testing_philosophy>
    </role>
  "

  run save_gap_report "${gap_report}"
  log "Gap report saved to .jaiph/tmp/qa_gap_report.md"
}

workflow write_tests() {
  if not run gap_report_nonempty {
    fail "No gap report found at .jaiph/tmp/qa_gap_report.md. Run analyze_gaps first."
  }
  const gap_report = run read_gap_report

  prompt "
    <role>
    You are a test engineer for the Jaiph codebase.

    <testing_philosophy>
    ${testing_philosophy}

    <task>
    Below is a gap report listing untested code paths, sorted by priority.
    Your task: write the missing tests, starting with high-priority gaps.

    Rules:
    - For golden output tests: add .jh fixture in test/fixtures/ and expected
      .sh output in test/expected/; align expected files with transpiler
      output and verify before committing.
    - For acceptance tests: add to test/acceptance/ using Node test runner
      (import test from 'node:test' and assert from 'node:assert').
    - For unit tests: add to test/ using Node test runner.
    - For e2e tests: add to e2e/tests/ following the Given/When/Then pattern
      with helpers from e2e/lib/common.sh (see docs/contributing.md for
      reference). Assert complete stdout/stderr and artifact text with
      expect_stdout, expect_out, expect_file, or assert_equals — not partial
      substring matches unless unavoidable and commented.
    - Do NOT modify existing tests.
    - Do NOT modify production code.
    - After writing tests, run: npm run build && npm test && npm run test:e2e
    - Fix any test failures that come from your new tests (wrong expectations,
      typos, etc). If a new test exposes a production bug, do NOT leave an
      intentionally failing test in the suite; instead document the bug in
      .jaiph/tmp/qa_bug_report.md with repro steps and mark the test as TODO
      or skip with a clear comment.

    Gap report:
    ${gap_report}
    </task>
    </testing_philosophy>
    </role>
  "
}

script mkdir_tmp_jaiph_qa() {
  mkdir -p .jaiph/tmp
}

workflow default() {
  ensure git.is_clean
  run mkdir_tmp_jaiph_qa
  run analyze_gaps
  run write_tests
  run ci.ensure_ci_passes
}
