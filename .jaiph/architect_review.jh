#!/usr/bin/env jaiph

import "./queue.jh" as queue

config {
  agent.backend = "claude"
  agent.claude_flags = "--permission-mode bypassPermissions"
}

script first_line_str() {
  source "${JAIPH_LIB}/strings.sh"
  first_line "$1"
}

script rest_lines_str() {
  source "${JAIPH_LIB}/strings.sh"
  rest_lines "$1"
}

script arg_nonempty() {
  [ -n "${1:-}" ]
}

script str_equals() {
  [ "$1" = "$2" ]
}

script task_has_dev_ready_marker() {
  printf '%s\n' "$1" | grep -q '<!-- dev-ready -->'
}

script queue_has_any_task_not_dev_ready() {
  local qf
  qf="${JAIPH_WORKSPACE:-.}/QUEUE.md"
  awk '
    BEGIN { bad=0 }
    /^## / {
      if (inblk && !marked) bad=1
      inblk=1
      marked=0
      next
    }
    inblk && /<!-- dev-ready -->/ { marked=1 }
    END {
      if (inblk && !marked) bad=1
      exit bad
    }
  ' "$qf"
}

workflow review_task {
  const result = prompt "
    You are a software architect reviewing a task from the Jaiph
    improvement queue. Jaiph is a TypeScript compiler and runtime
    for a DSL that transpiles to Bash.

    Determine whether the task below is ready for development.
    Evaluate against these criteria:

    1. **Clarity** — Unambiguous description. Specific, testable
       acceptance criteria.
    2. **Architecture fit** — Consistent with the codebase's grammar,
       compiler pipeline, and runtime conventions. Read relevant
       source files and docs to verify.
    3. **Code philosophy** — The proposed approach follows codebase
       principles: plain functions with explicit arguments, flat control
       flow, short files (<400 lines), no speculative abstractions, minimal
       touch surface (≤3 files per feature). Flag tasks whose scope or
       approach would violate these.
    4. **No conflicts** — Does not conflict with documented features
       or other queued tasks in QUEUE.md.
    5. **Feasibility** — Implementable with the current compiler/runtime
       infrastructure without depending on unfinished work.
    6. **Scope** — Appropriately sized for a single implementation
       cycle. Suggest splitting if too broad.

    Read the full QUEUE.md (QUEUE.md) for context on other
    queued tasks.

    If the task meets all criteria, respond with:
      verdict: dev-ready

    If NOT, respond with:
      verdict: needs-work
    and update the task block in QUEUE.md with a numbered list of
    questions, concerns, or recommendations that must be addressed
    before development can start. This is mandatory if you consider the task
    as not ready for development.

    If the task in the QUEUE.md already contains answers to the questions,
    merge the answers into the description, remove redundancies, but keep
    the original context and reasoning if it may help the developer. If all
    questions are answered, mark the task as dev-ready.

    If you are able to answer the questions yourself based on your knowledge
    of the codebase and the task, do so, and factor those answers into your
    evaluation.

    Task to review:
    $1
  " returns '{ verdict: string }'

  return "$result_verdict"
}

workflow review_one_header {
  const header = "$1"
  if not run arg_nonempty "$header" {
    return
  }
  const task = run queue.get_task_by_header "$header"
  if run task_has_dev_ready_marker "$task" {
    log "Already dev-ready: $header"
    return
  }
  const verdict = run review_task "$task"
  if run str_equals "$verdict" "dev-ready" {
    run queue.mark_task_dev_ready "$header"
    log "Marked dev-ready: $header"
  }
  else {
    log "Needs work: $header"
  }
}

workflow process_headers_recursive {
  const header = "$1"
  const remaining = "$2"
  run review_one_header "$header"
  if run arg_nonempty "$remaining" {
    const next = run first_line_str "$remaining"
    const rest = run rest_lines_str "$remaining"
    run process_headers_recursive "$next" "$rest"
  }
}

workflow default {
  const headers = run queue.get_all_task_headers
  const first = run first_line_str "$headers"
  const rest = run rest_lines_str "$headers"
  if run arg_nonempty "$first" {
    run process_headers_recursive "$first" "$rest"
  }
  if run queue_has_any_task_not_dev_ready {
    fail "One or more tasks need work. Review the agent output above."
  }
}
