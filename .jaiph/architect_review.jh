#!/usr/bin/env jaiph

import "jaiphlang/queue" as queue

config {
  agent.backend = "cursor"
  agent.default_model = "composer-2"
  agent.cursor_flags = "--force"
  # agent.backend = "claude"
  # agent.claude_flags = "--permission-mode bypassPermissions"
}

script first_line_str = `printf '%s\n' "$1" | head -n 1`

script rest_lines_str = `printf '%s\n' "$1" | tail -n +2`

script arg_nonempty = `[ -n "$1" ]`

script str_equals = `[ "$1" = "$2" ]`

script mkdir_p_simple = `mkdir -p "$1"`

script jaiph_tmp_dir = `printf '%s\n' "$JAIPH_WORKSPACE/.jaiph/tmp"`

script jaiph_review_body_file = `printf '%s\n' "$JAIPH_WORKSPACE/.jaiph/tmp/architect_review_body.txt"`

# Writes UTF-8 text to a path (path, then content).
script save_string_to_file = ```python3
import sys
if len(sys.argv) < 3:
    sys.exit(2)
path, content = sys.argv[1], sys.argv[2]
open(path, "w", encoding="utf-8").write(content)
```

# Packed as: first line = verdict, rest = updated_description (must stay top-level:
# const … = prompt """…""" is not supported inside ensure … catch — see parseRecoverStatement).
workflow architect_agent_review(task) {
  const result = prompt """
    You are a software architect reviewing a task from the Jaiph
    improvement queue. Jaiph is a TypeScript compiler and runtime
    for a DSL that transpiles to Bash.

    Determine whether the task below is ready for development.
    Evaluate against these criteria:

    1. **Clarity** — Unambiguous description. Specific, testable
       acceptance criteria.
    2. **Architecture fit** — Consistent with the codebase's grammar,
       compiler pipeline, and runtime conventions. Read relevant
       source files and docs to verify.
    3. **Code philosophy** — The proposed approach follows codebase
       principles: plain functions with explicit arguments, flat control
       flow, short files (<400 lines where possible), no speculative
       abstractions, minimal touch surface (≤3 files per feature preferably).
       Flag tasks whose scope or approach would violate these.
    4. **No conflicts** — Does not conflict with documented features
       or other queued tasks in QUEUE.md.
    5. **Feasibility** — Implementable with the current compiler/runtime
       infrastructure without depending on unfinished work.
    6. **Scope** — Appropriately sized for a single implementation
       cycle. Suggest splitting if too broad.

    Read the full QUEUE.md (QUEUE.md) for context on other
    queued tasks.

    Respond with JSON fields:
    - **verdict** — the string dev-ready or the string needs-work (JSON values).
    - **updated_description** — The full new task **body** only (markdown
      below the task heading line in QUEUE.md; do not repeat the H2 heading line).
      For needs-work, put a numbered list of questions, concerns, or
      recommendations here (mandatory). For dev-ready, put the merged/final
      body if you changed the text (e.g. merged answers); use an empty string
      if the body is unchanged and only the tag should be added.

    If the task in QUEUE.md already contains answers to prior questions,
    merge the answers into the description, remove redundancies, but keep
    useful context. If all questions are answered, use verdict dev-ready
    and include the merged body in updated_description when it changed.

    If you can answer open questions yourself from the codebase, do so and
    reflect that in your verdict and updated_description.

    Task to review:
    ${task}
  """
  returns "{ verdict: string, updated_description: string }"

  return """
    ${result.verdict}
    ${result.updated_description}
  """
}

workflow review_one_header(header) {
  run arg_nonempty(header) catch (err) {
    return ""
  }
  const task = run queue.get_task_by_header(header)
  run queue.task_is_dev_ready(task) catch (err) {
    const packed = run architect_agent_review(task)
    const verdict = run first_line_str(packed)
    const updated_description = run rest_lines_str(packed)
    const body_file = run jaiph_review_body_file()
    run mkdir_p_simple(run jaiph_tmp_dir())
    run str_equals(verdict, "dev-ready") catch (err) {
      run arg_nonempty(updated_description) catch (err) {
        fail "needs-work requires a non-empty updated_description (questions for the author)."
      }
      run save_string_to_file(body_file, updated_description)
      run queue.set_task_description_from_file(header, body_file)
      log "Needs work (description updated): ${header}"
      return ""
    }
    run arg_nonempty(updated_description) catch (err) {
      run queue.mark_task_dev_ready(header)
      log "Marked dev-ready: ${header}"
      return ""
    }
    run save_string_to_file(body_file, updated_description)
    run queue.set_task_description_from_file(header, body_file)
    run queue.mark_task_dev_ready(header)
    log "Marked dev-ready: ${header}"
    return ""
  }
  log "Already dev-ready: ${header}"
}

workflow process_headers_recursive(header, remaining) {
  run review_one_header(header)
  run arg_nonempty(remaining) catch (err) {
    return ""
  }
  const next = run first_line_str(remaining)
  const rest = run rest_lines_str(remaining)
  run process_headers_recursive(next, rest)
}

workflow maybe_process_headers(first, rest) {
  run arg_nonempty(first) catch (err) {
    return ""
  }
  run process_headers_recursive(first, rest)
}

workflow default() {
  const headers = run queue.get_all_task_headers()
  const first = run first_line_str(headers)
  const rest = run rest_lines_str(headers)
  run maybe_process_headers(first, rest)
  run queue.all_dev_ready() catch (err) {
    fail "One or more tasks need work. Review the agent output above."
  }
}
