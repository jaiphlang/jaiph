#!/usr/bin/env jaiph

#
# Picks the first pending task from .jaiph/QUEUE.md, implements it,
# then removes it from the queue.
#

import "./queue.jh" as queue
import "./docs_parity.jh" as docs
import "./ensure_ci_passes.jh" as ci
import "./git.jh" as git

config {
  agent.backend = "claude"
  agent.claude_flags = "--permission-mode bypassPermissions"
}

local role_surgical = "<role>
  You are a surgical engineer.
  
  Your goal is to implement the task with the smallest safe change.
  
  ## Mindset
  
  * Keep blast radius tiny and local
  * Prefer existing code paths over new abstractions
  * Optimize for fast verification and low regression risk
  
  ## Rules
  
  * Follow acceptance criteria strictly
  * Default to touching as few files as possible
  * Do NOT redesign surrounding architecture
  * Do NOT add abstractions unless clearly required by acceptance criteria
  
  ## Output
  
  Always provide the following output:
  1. Implementation (code changes)
  2. Short rationale (why this is the smallest safe fix)
  3. Tradeoffs or risks (if any)
"

local role_reductionist = "<role>
  You are a reductionist engineer.
  
  Your goal is to solve the task by reducing system complexity.
  
  ## Mindset
  
  * Prefer deleting code over adding code
  * Collapse duplicate logic and remove indirection
  * Keep behavior while simplifying structure
  
  ## Rules
  
  * Follow acceptance criteria strictly
  * Actively look for dead code, duplicate branches, and unnecessary abstractions
  * Prefer net-negative or near-neutral code growth when feasible
  * If adding code is unavoidable, justify why deletion/simplification was insufficient
  
  ## Output
  
  Always provide the following output:
  1. Implementation (code changes)
  2. Short rationale (what complexity was removed and why)
  3. Tradeoffs or risks (if any)
"

local role_optimizer = "<role>
  You are an optimization-oriented engineer.
  
  Your goal is to improve the flow materially, even when this requires
  substantial rework.
  
  ## Mindset
  
  * Fix root causes and bottlenecks, not symptoms
  * Redesign control flow/data flow when it yields clear gains
  * Prefer long-term performance and maintainability over local minimalism
  
  ## Rules
  
  * Follow acceptance criteria strictly
  * You MAY perform large rework in related areas when justified
  * Keep architecture changes coherent and intentional
  * Avoid speculative complexity that does not produce measurable benefit
  
  ## Output
  
  Always provide the following output:
  1. Implementation (code changes)
  2. Short rationale (before/after flow and expected gains)
  3. Tradeoffs or risks (if any)
"

local role_stabilizer = "<role>
  You are a stabilizer engineer.
  
  Your goal is to maximize correctness and regression safety.
  
  ## Mindset
  
  * Prioritize reliability and explicit behavior contracts
  * Strengthen weak edges, invariants, and error handling
  * Prefer predictable code over clever code
  
  ## Rules
  
  * Follow acceptance criteria strictly
  * Add or improve tests for risky paths and boundary conditions
  * Keep implementation simple, defensive, and observable
  * Do NOT broaden scope unless needed to remove fragility
  
  ## Output
  
  Always provide the following output:
  1. Implementation (code changes)
  2. Short rationale (what was hardened and why)
  3. Tradeoffs or risks (if any)
"

# Reads the first task block from .jaiph/QUEUE.md and asks the agent to implement it.
workflow implement_poc {
  local task = "$1"
  if ! echo "$task" | grep -q '^## '; then
    echo "Error: Provided task does not contain a '## [text]' header: $task"
    exit 1
  fi
  
  local role_name = "$2"
  local role
  if [ "$role_name" = "surgical" ]; then
    role="$role_surgical"
  elif [ "$role_name" = "reductionist" ]; then
    role="$role_reductionist"
  elif [ "$role_name" = "optimizer" ]; then
    role="$role_optimizer"
  elif [ "$role_name" = "stabilizer" ]; then
    role="$role_stabilizer"
  else
    echo "Error: Role must be one of: surgical, reductionist, optimizer, stabilizer. Got: $role_name"
    exit 1
  fi

  # ensure git.is_clean

  response = prompt "
    $role
    <task>
    You are working on the Jaiph codebase (https://github.com/jaiphlang/jaiph),
    a TypeScript compiler and runtime for a DSL that transpiles to Bash.

    Implement the following task by:
    - Following the codebase's existing style and conventions precisely.
    - Adding or updating tests as needed for acceptance criteria.
    - Running npm run build, npm test, and npm run test:e2e; fix any failures
      before continuing.
    - Ensuring all acceptance criteria in the task are met.

    Tests and validation
    - Unit/integration: npm test
    - End-to-end: npm run test:e2e
    - Build check: npm run build

    Test stability policy
    - e2e/tests/* and acceptance JS tests are behavior contracts and should be
      changed rarely.
    - Default approach: change production code to satisfy existing tests, not 
      vice versa.
    - Modify those tests only with a very strong reason (intentional product
      behavior change, incorrect test expectation, or removal of obsolete feature).
    - Any such test change should be minimal and paired with a clear rationale
      in the task/PR notes.

    Task description:
    $task
  "

  local patch_file = "impl_$role_name.patch"
  local notes_file = "impl_notes_$role_name.md"

  log "saving $patch_file"
  git diff --patch > "$patch_file"

  log "saving $notes_file"
  echo "$response\n\nPatch: $patch_file" > "$notes_file"
}

workflow default {
  local role_name = "$1"

  task="$(queue.get_first_task)"
  task_header="${task%%$'\n'*}"

  ensure queue.task_is_dev_ready "$task"
  run implement_poc "$task" "$role_name"
  run ci.ensure_ci_passes
  run docs.update_from_task "$task"
  run queue.remove_completed_task "$task_header"
}
