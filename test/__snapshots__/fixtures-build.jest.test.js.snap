exports[`fixture build snapshots build output matches snapshot 1`] = `
{
  "files": [
    "bootstrap_project.sh",
    "inbox.sh",
    "main.sh",
    "tools/security.sh",
  ],
  "outputByFile": {
    "bootstrap_project.sh": "#!/usr/bin/env bash

set -euo pipefail
jaiph_stdlib_path="\${JAIPH_STDLIB:-$HOME/.local/bin/jaiph_stdlib.sh}"
if [[ ! -f "$jaiph_stdlib_path" ]]; then
  echo "jaiph: stdlib not found at $jaiph_stdlib_path (set JAIPH_STDLIB or reinstall jaiph)" >&2
  exit 1
fi
source "$jaiph_stdlib_path"
if [[ "$(jaiph__runtime_api)" != "1" ]]; then
  echo "jaiph: incompatible jaiph stdlib runtime (required api=1)" >&2
  exit 1
fi
exec 7>&1
export JAIPH_STDOUT_SAVED=1

bootstrap_project::nodejs::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'nodejs'
  echo "Sorry, I cannot setup nodejs yet"
  exit 1
  jaiph::emit_workflow_summary_event WORKFLOW_END 'nodejs'
}

bootstrap_project::nodejs() {
  jaiph::run_step bootstrap_project::nodejs workflow bootstrap_project::nodejs::impl "$@"
}",
    "inbox.sh": "#!/usr/bin/env bash

set -euo pipefail
jaiph_stdlib_path="\${JAIPH_STDLIB:-$HOME/.local/bin/jaiph_stdlib.sh}"
if [[ ! -f "$jaiph_stdlib_path" ]]; then
  echo "jaiph: stdlib not found at $jaiph_stdlib_path (set JAIPH_STDLIB or reinstall jaiph)" >&2
  exit 1
fi
source "$jaiph_stdlib_path"
if [[ "$(jaiph__runtime_api)" != "1" ]]; then
  echo "jaiph: incompatible jaiph stdlib runtime (required api=1)" >&2
  exit 1
fi
exec 7>&1
export JAIPH_STDOUT_SAVED=1

inbox::researcher::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'researcher'
  jaiph::send 'findings' "$(echo '## findings')" 'researcher'
  jaiph::emit_workflow_summary_event WORKFLOW_END 'researcher'
}

inbox::researcher() {
  jaiph::run_step inbox::researcher workflow inbox::researcher::impl "$@"
}

inbox::analyst::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'analyst'
  echo "$1" > findings_file.md
  summary=$(echo "Summary of findings")
  jaiph::send 'summary' "$(echo "$summary")" 'analyst'
  jaiph::emit_workflow_summary_event WORKFLOW_END 'analyst'
}

inbox::analyst() {
  jaiph::run_step inbox::analyst workflow inbox::analyst::impl "$@"
}

inbox::reviewer::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'reviewer'
  jaiph::send 'final_summary' "$(echo "[reviewed] $1")" 'reviewer'
  jaiph::emit_workflow_summary_event WORKFLOW_END 'reviewer'
}

inbox::reviewer() {
  jaiph::run_step inbox::reviewer workflow inbox::reviewer::impl "$@"
}

# Orchestration / entrypoint workflow
inbox::default::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'default'
  jaiph::inbox_init
  jaiph::register_route 'findings' 'inbox::analyst'
  jaiph::register_route 'summary' 'inbox::reviewer'
  inbox::researcher
  jaiph::drain_queue
  jaiph::emit_workflow_summary_event WORKFLOW_END 'default'
}

inbox::default() {
  jaiph::run_step inbox::default workflow inbox::default::impl "$@"
}",
    "main.sh": "#!/usr/bin/env bash

set -euo pipefail
jaiph_stdlib_path="\${JAIPH_STDLIB:-$HOME/.local/bin/jaiph_stdlib.sh}"
if [[ ! -f "$jaiph_stdlib_path" ]]; then
  echo "jaiph: stdlib not found at $jaiph_stdlib_path (set JAIPH_STDLIB or reinstall jaiph)" >&2
  exit 1
fi
source "$jaiph_stdlib_path"
if [[ "$(jaiph__runtime_api)" != "1" ]]; then
  echo "jaiph: incompatible jaiph stdlib runtime (required api=1)" >&2
  exit 1
fi
exec 7>&1
export JAIPH_STDOUT_SAVED=1
source "$(dirname "\${BASH_SOURCE[0]}")/bootstrap_project.sh"
source "$(dirname "\${BASH_SOURCE[0]}")/tools/security.sh"

# Validates local build prerequisites.
main::project_ready::impl() {
  set -eo pipefail
  set +u
  test -f "package.json"
  test -n "$NODE_ENV"
}

main::project_ready() {
  jaiph::run_step main::project_ready rule jaiph::execute_readonly main::project_ready::impl "$@"
}

# Verifies the project compiles successfully.
main::build_passes::impl() {
  set -eo pipefail
  set +u
  npm run build
}

main::build_passes() {
  jaiph::run_step main::build_passes rule jaiph::execute_readonly main::build_passes::impl "$@"
}

# Orchestrates checks, prompt execution, and docs refresh.
# Arguments:
#   $1: Feature requirements passed to the prompt.
main::default::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'default'
  if ! main::project_ready; then
    bootstrap_project::nodejs
  fi
  export JAIPH_STEP_PARAM_KEYS='__prompt_impl,__preview,1'
  export JAIPH_PROMPT_PREVIEW='
    Build the applicati'
  jaiph::prompt "$JAIPH_PROMPT_PREVIEW" "1=$1" <<__JAIPH_PROMPT_25__

    Build the application using best practices.
    Follow requirements: $1
  
__JAIPH_PROMPT_25__
  main::build_passes
  tools::security::scan_passes
  main::update_docs
  jaiph::emit_workflow_summary_event WORKFLOW_END 'default'
}

main::default() {
  jaiph::run_step main::default workflow main::default::impl "$@"
}

# Refreshes documentation after a successful build.
main::update_docs::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'update_docs'
  export JAIPH_PROMPT_PREVIEW='Update docs'
  jaiph::prompt "$JAIPH_PROMPT_PREVIEW" <<__JAIPH_PROMPT_38__
Update docs
__JAIPH_PROMPT_38__
  jaiph::emit_workflow_summary_event WORKFLOW_END 'update_docs'
}

main::update_docs() {
  jaiph::run_step main::update_docs workflow main::update_docs::impl "$@"
}",
