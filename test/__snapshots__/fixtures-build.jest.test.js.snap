  rm -f "$_jaiph_send_rv_1"
  jaiph::send 'findings' "$_jaiph_send_msg" 'researcher'
  jaiph::emit_workflow_summary_event WORKFLOW_END 'researcher'
}

inbox::researcher() {
  jaiph::run_step inbox::researcher workflow inbox::researcher::impl "$@"
}

inbox::analyst::impl() {
  set -eo pipefail
  set +u
