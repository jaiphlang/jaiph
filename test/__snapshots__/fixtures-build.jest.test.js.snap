  jaiph::run_step inbox::write_findings_file script "$JAIPH_SCRIPTS/write_findings_file" "$1"
  local _jaiph_rv_summary; _jaiph_rv_summary=$(mktemp)
  JAIPH_RETURN_VALUE_FILE="$_jaiph_rv_summary" jaiph::run_step inbox::summarize_findings script "$JAIPH_SCRIPTS/summarize_findings"
  summary=""; [[ -s "$_jaiph_rv_summary" ]] && summary=$(<"$_jaiph_rv_summary")
