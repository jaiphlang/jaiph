  jaiph::emit_workflow_summary_event WORKFLOW_START 'default'
  jaiph::inbox_init
  jaiph::register_route 'findings' 'inbox::analyst'
  jaiph::register_route 'summary' 'inbox::reviewer'
  inbox::researcher
  jaiph::drain_queue
  jaiph::emit_workflow_summary_event WORKFLOW_END 'default'
}

inbox::default() {
  jaiph::run_step inbox::default workflow inbox::default::impl "$@"
