    "lang_redesign_smoke.sh": "#!/usr/bin/env bash

set -euo pipefail
export JAIPH_SCRIPTS="\${JAIPH_SCRIPTS:-$(cd "$(dirname "\${BASH_SOURCE[0]}")/scripts" && pwd)}"

lang_redesign_smoke::always_ok::impl() {
  set -eo pipefail
  set +u
  jaiph::run_step lang_redesign_smoke::always_ok_impl script "$JAIPH_SCRIPTS/always_ok_impl"
}

lang_redesign_smoke::always_ok() {
  jaiph::run_step lang_redesign_smoke::always_ok rule jaiph::execute_readonly lang_redesign_smoke::always_ok::impl "$@"
}

lang_redesign_smoke::always_ok_impl() {
  jaiph::run_step lang_redesign_smoke::always_ok_impl script "$JAIPH_SCRIPTS/always_ok_impl" "$@"
}

always_ok_impl() {
  lang_redesign_smoke::always_ok_impl "$@"
}

lang_redesign_smoke::noop() {
  jaiph::run_step lang_redesign_smoke::noop script "$JAIPH_SCRIPTS/noop" "$@"
}

noop() {
  lang_redesign_smoke::noop "$@"
}

lang_redesign_smoke::wf_fail::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'wf_fail'
  echo "expected failure" >&2
  exit 1
  jaiph::emit_workflow_summary_event WORKFLOW_END 'wf_fail'
}

lang_redesign_smoke::wf_fail() {
  jaiph::run_step lang_redesign_smoke::wf_fail workflow lang_redesign_smoke::wf_fail::impl "$@"
}

lang_redesign_smoke::wf_const::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'wf_const'
  local msg; msg="hello"
  jaiph::log "$msg"
  jaiph::emit_workflow_summary_event WORKFLOW_END 'wf_const'
}

lang_redesign_smoke::wf_const() {
  jaiph::run_step lang_redesign_smoke::wf_const workflow lang_redesign_smoke::wf_const::impl "$@"
}

lang_redesign_smoke::wf_wait::impl() {
  set -eo pipefail
  set +u
  local -a _jaiph_async_run_pids=()
  jaiph::emit_workflow_summary_event WORKFLOW_START 'wf_wait'
  jaiph::run_step lang_redesign_smoke::noop script "$JAIPH_SCRIPTS/noop" &
  _jaiph_async_run_pids+=($!)
  if [[ "\${#_jaiph_async_run_pids[@]}" -eq 0 ]]; then
    wait
  else
    local _jaiph_wait_status=0
    local _jaiph_pid
    for _jaiph_pid in "\${_jaiph_async_run_pids[@]}"; do
      if ! wait "$_jaiph_pid"; then _jaiph_wait_status=1; fi
    done
    # Reap any non-managed background jobs started by raw shell steps.
    if ! wait; then _jaiph_wait_status=1; fi
    _jaiph_async_run_pids=()
    if [[ "$_jaiph_wait_status" -ne 0 ]]; then return 1; fi
  fi
  jaiph::emit_workflow_summary_event WORKFLOW_END 'wf_wait'
}

lang_redesign_smoke::wf_wait() {
  jaiph::run_step lang_redesign_smoke::wf_wait workflow lang_redesign_smoke::wf_wait::impl "$@"
}

lang_redesign_smoke::wf_brace_if::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'wf_brace_if'
  if lang_redesign_smoke::always_ok; then
    jaiph::log "then"
  elif ! lang_redesign_smoke::always_ok; then
    jaiph::log "elif"
  else
    jaiph::log "else"
  fi
  jaiph::emit_workflow_summary_event WORKFLOW_END 'wf_brace_if'
}

lang_redesign_smoke::wf_brace_if() {
  jaiph::run_step lang_redesign_smoke::wf_brace_if workflow lang_redesign_smoke::wf_brace_if::impl "$@"
}

lang_redesign_smoke::default::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'default'
  lang_redesign_smoke::always_ok
  jaiph::emit_workflow_summary_event WORKFLOW_END 'default'
}

lang_redesign_smoke::default() {
  jaiph::run_step lang_redesign_smoke::default workflow lang_redesign_smoke::default::impl "$@"
}",
    "main.sh": "#!/usr/bin/env bash

set -euo pipefail
export JAIPH_SCRIPTS="\${JAIPH_SCRIPTS:-$(cd "$(dirname "\${BASH_SOURCE[0]}")/scripts" && pwd)}"
source "$(dirname "\${BASH_SOURCE[0]}")/bootstrap_project.sh"
source "$(dirname "\${BASH_SOURCE[0]}")/tools/security.sh"

# Validates local build prerequisites.
main::project_ready::impl() {
  set -eo pipefail
  set +u
  jaiph::run_step main::project_ready_impl script "$JAIPH_SCRIPTS/project_ready_impl"
}

main::project_ready() {
  jaiph::run_step main::project_ready rule jaiph::execute_readonly main::project_ready::impl "$@"
}

# Verifies the project compiles successfully.
main::build_passes::impl() {
  set -eo pipefail
  set +u
  jaiph::run_step main::build_passes_impl script "$JAIPH_SCRIPTS/build_passes_impl"
}

main::build_passes() {
  jaiph::run_step main::build_passes rule jaiph::execute_readonly main::build_passes::impl "$@"
}

main::project_ready_impl() {
  jaiph::run_step main::project_ready_impl script "$JAIPH_SCRIPTS/project_ready_impl" "$@"
}

project_ready_impl() {
  main::project_ready_impl "$@"
}

main::build_passes_impl() {
  jaiph::run_step main::build_passes_impl script "$JAIPH_SCRIPTS/build_passes_impl" "$@"
}

build_passes_impl() {
  main::build_passes_impl "$@"
}

# Orchestrates checks, prompt execution, and docs refresh.
# Arguments:
#   $1: Feature requirements passed to the prompt.
main::default::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'default'
  if ! main::project_ready; then
    jaiph::run_step bootstrap_project::nodejs workflow bootstrap_project::nodejs::impl
  fi
  export JAIPH_STEP_PARAM_KEYS='__prompt_impl,__preview,1'
  export JAIPH_PROMPT_PREVIEW='
    Build the applicati'
  jaiph::prompt "$JAIPH_PROMPT_PREVIEW" "1=$1" <<__JAIPH_PROMPT_33__

    Build the application using best practices.
    Follow requirements: $1
  
__JAIPH_PROMPT_33__
  main::build_passes
  tools::security::scan_passes
  main::update_docs
  jaiph::emit_workflow_summary_event WORKFLOW_END 'default'
}

main::default() {
  jaiph::run_step main::default workflow main::default::impl "$@"
}

# Refreshes documentation after a successful build.
main::update_docs::impl() {
  set -eo pipefail
  set +u
  jaiph::emit_workflow_summary_event WORKFLOW_START 'update_docs'
  export JAIPH_PROMPT_PREVIEW='Update docs'
  jaiph::prompt "$JAIPH_PROMPT_PREVIEW" <<__JAIPH_PROMPT_46__
Update docs
__JAIPH_PROMPT_46__
  jaiph::emit_workflow_summary_event WORKFLOW_END 'update_docs'
}

main::update_docs() {
  jaiph::run_step main::update_docs workflow main::update_docs::impl "$@"
}",
