channel findings
channel summary
channel final_summary

workflow researcher() {
  findings <- run emit_findings()
}

script emit_findings = `echo '## findings'`

script write_findings_file = `echo "$1" > findings_file.md`

script summarize_findings = `echo "Summary of findings"`

script review_summary = `echo "[reviewed] $1"`

workflow analyst(message, chan, sender) {
  run write_findings_file(message)
  summary = run summarize_findings()
  summary <- "${summary}"
}

workflow reviewer(message, chan, sender) {
  final_summary <- run review_summary(message)
}

# Orchestration / entrypoint workflow
workflow default() {
  run researcher()
  findings -> analyst
  summary -> reviewer
}
