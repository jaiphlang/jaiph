#!/usr/bin/env jaiph

rule always_ok {
  run always_ok_impl
}

script always_ok_impl() {
  echo ok
}

script noop() {
  :
}

workflow wf_fail {
  fail "expected failure"
}

workflow wf_const {
  const msg = "hello"
  log "$msg"
}

workflow wf_async {
  run async noop
}

workflow wf_brace_if {
  if ensure always_ok {
    log "then"
  }
  else if not ensure always_ok {
    log "elif"
  }
  else {
    log "else"
  }
}

workflow default {
  ensure always_ok
}
