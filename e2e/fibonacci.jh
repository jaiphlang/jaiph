#!/usr/bin/env jaiph

rule ensure_is_number {
  if ! [[ "$1" =~ ^[0-9]+$ ]]; then
    echo "Expected a non-negative integer, got: $1" >&2
    exit 1
  fi
}

function fib() {
  local n="$1"
  if [ "$n" -le 1 ]; then
    return "$n"
  fi
  local a=0 b=1 i c
  for ((i=2; i<=n; i++)); do
    c=$((a + b))
    a=$b
    b=$c
  done
  return "$b"
}

workflow default {
  n="${1:-10}"
  ensure ensure_is_number "$n"
  result = run fib "$n"
  echo "$result"
}
