#!/usr/bin/env jaiph
# E2E fixture: assignment capture for ensure and shell.
script echo_line_impl = "echo \"this goes to logs only\""

script shell_capture = "echo shell-capture"

script format_output = "printf '%s\n' \"response=$1\" \"out=$2\""

rule echo_line() {
  run echo_line_impl()
  return "captured-value"
}
workflow default() {
  response = ensure echo_line()
  out = run shell_capture()
  run format_output("${response}", "${out}")
}
