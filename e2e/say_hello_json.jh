#!/usr/bin/env jaiph

config {
  agent.backend = "claude"
}

rule name_was_provided {
  if [ -z "$1" ]; then
    logerr "You didn't provide your name :("
    exit 1
  fi
}

workflow default(name) {
  ensure name_was_provided("${name}")

  response = prompt "Say hello to ${name} and provide a fun fact about a person with the same name." returns "{ hello: string, fact: string }"

  log "${response_fact}"
}
