#!/usr/bin/env jaiph

script name_was_provided_impl() {
  if [ -z "$1" ]; then
    echo "You didn't provide your name :(" >&2
    exit 1
  fi
}

rule name_was_provided {
  run name_was_provided_impl "$1"
}

workflow default {
  ensure name_was_provided "$1"

  response = prompt "
    Say hello to $1 and provide your model name, and then a fun fact about a person with the same name.
    Respond with a single line. Do not inspect files or run tools.
  "

  log "$response"
}
