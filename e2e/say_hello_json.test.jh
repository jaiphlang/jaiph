#!/usr/bin/env jaiph

import "say_hello_json.jh" as hello

test "without name, workflow fails with validation message" {
  # When
  response = hello.default allow_failure

  # Then
  expectEqual response "You didn't provide your name"
}

test "with name, returns greeting and logs response" {
  # Given
  mock prompt "The user wants me to provide a JSON output, so here it is: {\"hello\": \"Hello Alice!\", \"fact\": \"Alice in Wonderland was written by Lewis Carroll.\"}"

  # When
  hello.default "Alice"
}
