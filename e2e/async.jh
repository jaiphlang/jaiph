#!/usr/bin/env jaiph

local prompt_text = 'Say: "Greetings! I am [model name]."'

workflow cursor_say_hello {
  config {
    agent.backend = "cursor"
  }
  response = prompt "$prompt_text"
  log "$response"
}
  
workflow claude_say_hello {
  config {
    agent.backend = "cursor"
    agent.default_model = "gpt-5.5"
  }
  response = prompt "$prompt_text"
  log "$response"
}

workflow default {
  run cursor_say_hello "$1" &
  run claude_say_hello "$1" &
  wait
}
