#!/usr/bin/env bash

set -euo pipefail

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ]; then
  GREEN=''
  YELLOW=''
  RED=''
  BOLD=''
  DIM=''
  NC=''
else
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  RED='\033[0;31m'
  BOLD='\033[1m'
  DIM='\033[2m'
  NC='\033[0m'
fi

print_step()    { echo -e "${DIM}▸ ${1}${NC}"; }
print_success() { echo -e "${GREEN}✓ ${1}${NC}"; }
print_warning() { echo -e "${YELLOW}! ${1}${NC}"; }
print_error()   { echo -e "${RED}✗ ${1}${NC}"; }

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    print_error "Missing required command: $1"
    exit 1
  fi
}

canonical_dir() {
  local dir="$1"
  mkdir -p "${dir}"
  (cd "${dir}" && pwd)
}

# Refuse install/remove unless the target is exactly ${BIN_DIR}/jaiph (canonical).
assert_install_paths() {
  local bin_dir_canon target_canon

  if [ -z "${BIN_DIR}" ]; then
    print_error "JAIPH_BIN_DIR is empty"
    exit 1
  fi
  if [[ "${BIN_DIR}" == *$'\n'* || "${BIN_DIR}" == *$'\r'* ]]; then
    print_error "JAIPH_BIN_DIR must not contain newline characters"
    exit 1
  fi
  if [ "$(basename "${TARGET}")" != "jaiph" ]; then
    print_error "Install target basename must be jaiph (got $(basename "${TARGET}"))"
    exit 1
  fi

  bin_dir_canon="$(canonical_dir "${BIN_DIR}")"
  target_canon="${bin_dir_canon}/jaiph"

  case "${bin_dir_canon}" in
    /|/bin|/sbin|/usr/bin|/usr/sbin)
      print_error "Refusing to install into system directory ${bin_dir_canon}"
      echo "Set JAIPH_BIN_DIR to a user-owned directory (for example \$HOME/.local/bin)." >&2
      exit 1
      ;;
  esac

  BIN_DIR="${bin_dir_canon}"
  TARGET="${target_canon}"

  if [ -e "${TARGET}" ]; then
    if [ -d "${TARGET}" ]; then
      print_error "Refusing to replace directory at ${TARGET}"
      exit 1
    fi
    if [ ! -f "${TARGET}" ]; then
      print_error "Refusing to replace non-regular file at ${TARGET}"
      exit 1
    fi
  fi
}

assert_safe_install_target() {
  local source_path="$1"
  assert_install_paths
  if [ ! -f "${source_path}" ]; then
    print_error "Install source is not a regular file: ${source_path}"
    exit 1
  fi
}

# Promote a built/downloaded binary to TARGET without overwriting in place.
# cp onto an existing path reuses the inode; on macOS a running jaiph can leave
# the new bytes at that path unexecutable (SIGKILL on --version). Verify in a
# staging file, remove the old install path, then mv into place (fresh inode).
install_jaiph_binary() {
  local source_path="$1"
  assert_safe_install_target "${source_path}"

  local stage
  stage="$(mktemp "${BIN_DIR}/.jaiph.install.XXXXXX")"
  cp "${source_path}" "${stage}"
  chmod 755 "${stage}"

  local version_out=""
  if ! version_out="$("${stage}" --version 2>&1)"; then
    rm -f "${stage}"
    print_error "Binary verification failed (${stage} --version)"
    echo "${version_out}" >&2
    exit 1
  fi

  rm -f "${TARGET}"
  mv "${stage}" "${TARGET}"
  printf '%s\n' "${version_out}"
}

# Local-source mode: JAIPH_REPO_URL env or first arg is a local directory
# containing a package.json. Both env and arg are accepted so callers can
# supply the repo path either way (docs/install-from-local.sh uses both).
JAIPH_FROM_LOCAL=
if [ -n "${JAIPH_REPO_URL+x}" ] && [ -d "${JAIPH_REPO_URL}" ] && [ -f "${JAIPH_REPO_URL}/package.json" ]; then
  JAIPH_FROM_LOCAL=1
  JAIPH_REPO_URL="$(cd "${JAIPH_REPO_URL}" && pwd)"
elif [ -n "${1+x}" ] && [ -d "${1}" ] && [ -f "${1}/package.json" ]; then
  JAIPH_FROM_LOCAL=1
  JAIPH_REPO_URL="$(cd "${1}" && pwd)"
fi

BIN_DIR="${JAIPH_BIN_DIR:-$HOME/.local/bin}"
TARGET="${BIN_DIR}/jaiph"
assert_install_paths

echo ""
echo -e "${BOLD}Jaiph installer${NC}"
echo ""

if [ -n "${JAIPH_FROM_LOCAL}" ]; then
  # Build the standalone binary from the local checkout. Parity with the
  # release-asset path: a single self-contained executable, no shim, no
  # LIB_DIR runtime tree.
  require_cmd npm
  require_cmd bun

  print_step "Using local source at ${JAIPH_REPO_URL}"

  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "${tmp_dir}"' EXIT

  print_step "Copying (includes uncommitted changes)..."
  cp -R "${JAIPH_REPO_URL}" "${tmp_dir}/src"
  rm -rf "${tmp_dir}/src/.git" "${tmp_dir}/src/node_modules"

  print_step "Installing dependencies..."
  (cd "${tmp_dir}/src" && npm install >/dev/null 2>&1)

  print_step "Building standalone binary..."
  (cd "${tmp_dir}/src" && npm run build:standalone >/dev/null 2>&1)

  if [ ! -f "${tmp_dir}/src/dist/jaiph" ]; then
    print_error "Build did not produce dist/jaiph"
    exit 1
  fi

  print_step "Installing binary to ${TARGET}..."
  JAIPH_VERSION="$(install_jaiph_binary "${tmp_dir}/src/dist/jaiph")"
  echo ""
  print_success "Installed ${JAIPH_VERSION} to ${TARGET}"
else
  # Download a pre-built per-platform binary from the GitHub Release for the
  # resolved ref. Asset names are fixed by docs/contributing.md → "Release
  # asset naming contract".
  require_cmd curl

  if command -v sha256sum >/dev/null 2>&1; then
    sha256_check() { sha256sum "$1" | awk '{print $1}'; }
  elif command -v shasum >/dev/null 2>&1; then
    sha256_check() { shasum -a 256 "$1" | awk '{print $1}'; }
  else
    print_error "Missing required command: sha256sum or shasum"
    exit 1
  fi

  uname_s="$(uname -s)"
  uname_m="$(uname -m)"
  case "${uname_s}" in
    Darwin) os="darwin" ;;
    Linux)  os="linux" ;;
    MINGW*|MSYS*|CYGWIN*|Windows_NT)
      print_error "Unsupported platform: ${uname_s} ${uname_m}"
      echo "On Windows, install with PowerShell instead:"
      echo "  irm https://jaiph.org/install.ps1 | iex"
      echo "Or build from source per https://jaiph.org/contributing#installing-from-source"
      exit 1
      ;;
    *)
      print_error "Unsupported platform: ${uname_s} ${uname_m}"
      echo "Build from source per https://jaiph.org/contributing#installing-from-source"
      exit 1
      ;;
  esac
  case "${uname_m}" in
    arm64|aarch64) arch="arm64" ;;
    x86_64|x64)    arch="x64" ;;
    *)
      print_error "Unsupported platform: ${uname_s} ${uname_m}"
      echo "Build from source per https://jaiph.org/contributing#installing-from-source"
      exit 1
      ;;
  esac

  REPO_REF="${1:-${JAIPH_REPO_REF:-v0.11.0}}"
  BIN_NAME="jaiph-${os}-${arch}"
  BASE_URL="${JAIPH_RELEASE_BASE_URL:-https://github.com/jaiphlang/jaiph/releases/download/${REPO_REF}}"

  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "${tmp_dir}"' EXIT

  print_step "Downloading ${BIN_NAME} (${REPO_REF})..."
  if ! curl -fsSL -o "${tmp_dir}/${BIN_NAME}" "${BASE_URL}/${BIN_NAME}"; then
    print_error "Failed to download ${BASE_URL}/${BIN_NAME}"
    exit 1
  fi

  print_step "Downloading SHA256SUMS..."
  if ! curl -fsSL -o "${tmp_dir}/SHA256SUMS" "${BASE_URL}/SHA256SUMS"; then
    print_error "Failed to download ${BASE_URL}/SHA256SUMS"
    exit 1
  fi

  print_step "Downloading SHA256SUMS.minisig..."
  if ! curl -fsSL -o "${tmp_dir}/SHA256SUMS.minisig" "${BASE_URL}/SHA256SUMS.minisig"; then
    print_error "Failed to download ${BASE_URL}/SHA256SUMS.minisig"
    echo "The release signature file is missing. This may indicate a compromised or incomplete release." >&2
    echo "Install manually from source: https://jaiph.org/contributing#installing-from-source" >&2
    exit 1
  fi

  # Jaiph release signing public key (minisign). Canonical copy: jaiph.pub (repo root).
  # Releases are signed with: minisign -S -s jaiph.key -m SHA256SUMS
  # Verify manually:          minisign -V -P "${JAIPH_MINISIGN_PUBLIC_KEY}" -m SHA256SUMS
  # Key generation/rotation:  see docs/contributing.md → "Release signing"
  JAIPH_MINISIGN_PUBLIC_KEY="${JAIPH_MINISIGN_PUBLIC_KEY:-RWTQyxCqm5agwxi7ZwlGHc/kwGqT7QQjy9FxNGQGM/Y+m6LWsrk2l4fQ}"
  if [ -n "${JAIPH_MINISIGN_PUBLIC_KEY}" ] && command -v minisign >/dev/null 2>&1; then
    print_step "Verifying release signature..."
    if ! minisign -V -P "${JAIPH_MINISIGN_PUBLIC_KEY}" -m "${tmp_dir}/SHA256SUMS" \
        -x "${tmp_dir}/SHA256SUMS.minisig" >/dev/null 2>&1; then
      print_error "Release signature verification failed for SHA256SUMS"
      echo "The signature does not match the release signing key." >&2
      echo "This may indicate a tampered download. Do not proceed." >&2
      exit 1
    fi
    print_success "Release signature verified"
  else
    print_warning "Skipping detached-signature verification (minisign not installed)"
    echo "  Install minisign for full verification: https://jedisct1.github.io/minisign/" >&2
  fi

  print_step "Verifying checksum..."
  expected_sum="$(awk -v name="${BIN_NAME}" '$2 == name || $2 == "*"name { print $1 }' "${tmp_dir}/SHA256SUMS")"
  if [ -z "${expected_sum}" ]; then
    print_error "No checksum entry for ${BIN_NAME} in SHA256SUMS"
    exit 1
  fi
  actual_sum="$(sha256_check "${tmp_dir}/${BIN_NAME}")"
  if [ "${expected_sum}" != "${actual_sum}" ]; then
    print_error "Checksum mismatch for ${BIN_NAME}"
    echo "  expected: ${expected_sum}"
    echo "  got:      ${actual_sum}"
    exit 1
  fi

  print_step "Installing binary to ${TARGET}..."
  JAIPH_VERSION="$(install_jaiph_binary "${tmp_dir}/${BIN_NAME}")"
  echo ""
  print_success "Installed ${JAIPH_VERSION} to ${TARGET}"
fi

if [[ ":${PATH}:" == *":${BIN_DIR}:"* ]]; then
  print_success "${BIN_DIR} is already on PATH"
  echo ""
  echo "Try:"
  echo "  jaiph --version"
  echo "  jaiph --help"
else
  print_warning "${BIN_DIR} is not on PATH"
  echo ""
  echo "Add PATH for zsh:"
  echo "  echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.zshrc && source ~/.zshrc"
  echo ""
  echo "Add PATH for bash:"
  echo "  echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.bashrc && source ~/.bashrc"
  echo ""
  echo "Then verify:"
  echo "  jaiph --version"
fi
echo ""
